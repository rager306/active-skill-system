# .env.example - copy to .env and fill in real values.
# Only NON-SECRET keys are mirrored here. Secret values must never be committed.

# Observability (M040)
# Directory for the rotating log file sink (logs/app.log).
LOG_DIR=logs

# Sandbox persistence (M049 cross-session knowledge)
# LadybugDB graph path: LoopGraph provenance + trajectory accumulates here.
# MUST be on disk (NOT :memory:) for cross-session learning.
SANDBOX_GRAPH_PATH=runs/sandbox_graph.lbdb
# Ratchet ledger path: permanent entries for failed runs (fills over time).
SANDBOX_RATCHET_PATH=runs/ratchet.jsonl
# Sandbox log directory: structured per-run logs (one file per session).
SANDBOX_LOG_DIR=logs/sandbox

# LadybugDB options
# Auto-checkpoint flushes WAL to disk on shutdown (crash-safety).
LADYBUG_AUTO_CHECKPOINT=true
# Checkpoint threshold: bytes of WAL before forced checkpoint.
LADYBUG_CHECKPOINT_THRESHOLD=100000

# LLM provider gateway (Anthropic-compatible; e.g. MiniMax via gateway)
ANTHROPIC_BASE_URL=https://your-gateway.example.com
ANTHROPIC_MODEL=your-primary-model
ANTHROPIC_SMALL_FAST_MODEL=your-fast-model

# Per-request timeout (milliseconds) for LLM calls.
API_TIMEOUT_MS=60000

# Claude Code harness hints (optional)
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
CLAUDE_CODE_SUBAGENT_MODEL=
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=

# Secrets (DO NOT put real values in .env.example)
# ANTHROPIC_AUTH_TOKEN=  <- set this ONLY in your local .env, never commit.